{
  "manifest_version": 3,
  "name": "Alpha.date AI – Помощник",
  "version": "2.2.0",
  "description": "AI-помощник + автоматический захват логинов для alpha.date",
  "permissions": ["storage"],
  "host_permissions": ["*://*.alpha.date/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.alpha.date/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://*.alpha.date/*"]
    }
  ]
}
